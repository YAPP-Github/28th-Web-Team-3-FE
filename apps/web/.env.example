# --- apps/web ---
# Point at the SAME sqlite file you migrated in packages/auth (absolute path recommended,
# since the web app's cwd differs from the auth package).
DB_DIALECT=sqlite
DATABASE_URL=../../packages/auth/drizzle/dev.sqlite

BETTER_AUTH_SECRET=dev-insecure-secret-change-me
BETTER_AUTH_URL=http://localhost:3000
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Same-origin in dev; the auth client calls /api/auth/* on the current host.
# NEXT_PUBLIC_AUTH_URL=
# NEXT_PUBLIC_API_URL=
