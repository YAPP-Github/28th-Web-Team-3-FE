# --- apps/native ---
# The WebView target. In dev point at the machine running `pnpm --filter web dev`.
# Use your LAN IP (not localhost) when testing on a physical device.
# iOS 시뮬레이터: localhost / Android 에뮬레이터: 10.0.2.2 (미설정 시 코드에서 자동 분기)
# EXPO_PUBLIC_WEB_URL=http://localhost:3000

# Cookie domain used when injecting the session cookie. Must match the web origin.
# dev: localhost  |  prod: example.com (or the bare apex)
EXPO_PUBLIC_COOKIE_DOMAIN=localhost
