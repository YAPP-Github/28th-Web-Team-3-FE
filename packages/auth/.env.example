# --- packages/auth ---
# Dev defaults to SQLite. Migrations + the dev db file live under packages/auth/drizzle/.
DB_DIALECT=sqlite
DATABASE_URL=./drizzle/dev.sqlite

# Generate a real secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=dev-insecure-secret-change-me
BETTER_AUTH_URL=http://localhost:3000

# Origins allowed to call the auth API (web + Expo dev tunnel). Comma-separated.
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Prod cookie sharing across subdomains the WebView may navigate to, e.g. .example.com
# Leave empty in dev (host-only cookie on localhost).
AUTH_COOKIE_DOMAIN=

# --- Postgres (prod) ---
# DB_DIALECT=postgres
# DATABASE_URL=postgres://user:pass@host:5432/db
