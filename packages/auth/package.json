{
  "name": "@repo/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./server": "./src/server.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/db/schema.ts",
    "./db": "./src/db/index.ts"
  },
  "scripts": {
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "better-auth generate --output ./src/db/schema.ts"
  },
  "dependencies": {
    "@repo/schema": "workspace:*",
    "better-auth": "catalog:",
    "better-sqlite3": "catalog:",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
